{
  "name": "finder-mcp",
  "version": "2.0.0",
  "description": "MCP server for macOS Finder - file operations, Spotlight search, and tags via the Model Context Protocol",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "finder-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "echo \"No linter configured\"",
    "format": "echo \"No formatter configured\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "finder",
    "macos",
    "spotlight",
    "files",
    "model-context-protocol",
    "ai",
    "claude"
  ],
  "author": "Thomas Vincent",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
